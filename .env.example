# ─── Environment variables for Glaukos Evidence Hub demo ────────────────────
# Copy to .env.local for local dev (`cp .env.example .env.local`), or set these
# in the Vercel project: Settings → Environment Variables (Production scope).
#
# .env.local is gitignored — these values never get committed.

# Anthropic API key — powers AI chat (/api/chat) and the dossier writing agent
# (/api/dossier/write). No fallback: if unset, those AI routes throw, but the
# rest of the app still loads.
ANTHROPIC_API_KEY=sk-ant-...

# Demo gate password (/api/access). Shared with stakeholders.
# If unset, the app falls back to a built-in demo password (see lib/env.ts),
# so set this for a real deployment.
DEMO_PASSWORD=change-me

# Secret used to sign the demo session cookie. Use a long random string.
# If unset, an insecure built-in fallback is used — always set this in Vercel.
SESSION_SECRET=generate-a-long-random-string

# Optional. Demo mode is ON by default. Set to "false" to disable it.
# DEMO_MODE=false
